# ─── Squarespace Checkout Bot ───────────────────────────────────
# Copy this to .env and fill in your details:  cp .env.example .env

# Store
STORE_URL=https://example.com
STORE_PATH=/store

# Product target (pick one):
#   Direct URL:       PRODUCT_URL=/store/p/product-slug
#   By ID:            ITEM_ID=abc123  SKU=123456
#   Keyword search:   PRODUCT_SEARCH=some keyword
#   Existing cart:    CART_TOKEN=your-cart-token

# Customer / shipping
EMAIL=
FIRST_NAME=
LAST_NAME=
ADDRESS1=
ADDRESS2=
CITY=
STATE=
ZIP=
COUNTRY=US
PHONE=

# Payment (sent directly to Stripe, never touches the store's servers)
CARD_NUMBER=
CARD_EXP_MONTH=12
CARD_EXP_YEAR=2027
CARD_CVC=

# Bot options
QUANTITY=1
DRY_RUN=true
MAX_PRICE=0
POLL_INTERVAL=10
SCAN_DAYS=7
